# ==============================================================
# OKX Grid Bot — environment variables / 环境变量样例
# Copy this file to `.env` and fill in real values.
# 复制此文件为 .env 后填入实际值。`.env` is gitignored.
# ==============================================================

# ---------- OKX API credentials / OKX API 凭证 ----------
# Create at https://www.okx.com/account/my-api  (start with the demo / 模拟盘)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# 1 = demo trading / 模拟盘   0 = live trading / 实盘
OKX_SIMULATED=1


# ---------- LLM API keys (configure any one or more) / 大模型 API Key ----------
# DeepSeek    https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenAI      https://platform.openai.com
OPENAI_API_KEY=

# Anthropic   https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Qwen / 通义千问  https://dashscope.console.aliyun.com
QWEN_API_KEY=

# Moonshot    https://platform.moonshot.cn
MOONSHOT_API_KEY=

# Zhipu GLM / 智谱   https://open.bigmodel.cn
GLM_API_KEY=


# ---------- Web UI / Web 控制台 ----------
WEBUI_USER=admin
WEBUI_PASS=please-change-me
# Generate with: python -c "import secrets;print(secrets.token_hex(32))"
# 用上面命令生成长随机串
WEBUI_SECRET=replace-with-long-random-hex-string
